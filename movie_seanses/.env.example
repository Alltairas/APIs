# Copie ce fichier vers .env et remplis les vraies valeurs
# .env est ignoré par git (voir .gitignore)
BOT_TOKEN=123456789:AAH-replace-me-with-the-token-from-BotFather

# CHAT_ID accepte une liste séparée par virgules.
# - id positif  → DM (utilisateur)
# - id négatif  → groupe / supergroupe
# Exemple: CHAT_ID=123456789,-987654321
CHAT_ID=987654321
